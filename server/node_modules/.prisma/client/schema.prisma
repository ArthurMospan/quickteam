datasource db {
  provider = "sqlite"
  url      = "file:./kanban.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  language  String   @default("en")
  role      String   @default("Member") // "Admin" or "Member"
  createdAt DateTime @default(now())

  workspaces    WorkspaceMember[]
  comments      Comment[]
  activities    Activity[]
  assignedTasks TaskAssignee[]
  tasks         Task[]            @relation("TaskAssigneeRelation")
  notifications Notification[]
}

model Workspace {
  id             String   @id @default(uuid())
  name           String
  description    String?
  defaultColumns String?  @default("[\"Column 1\",\"Column 2\",\"Column 3\",\"Column 4\"]")
  createdAt      DateTime @default(now())

  members  WorkspaceMember[]
  projects Project[]
}

model WorkspaceMember {
  id          String @id @default(uuid())
  userId      String
  workspaceId String
  role        String @default("MEMBER")

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns   Column[]
  tags      ProjectTag[]
}

model Column {
  id        String @id @default(uuid())
  title     String
  order     Int
  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  color       String    @default("white")
  hasBookmark Boolean   @default(false)
  priority    String    @default("Medium")
  deadline    DateTime?
  order       Int
  createdAt   DateTime  @default(now())

  columnId String
  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssigneeRelation", fields: [assigneeId], references: [id])

  comments   Comment[]
  activities Activity[]

  assignees   TaskAssignee[]
  tags        TaskTag[]
  attachments Attachment[]
}

model TaskAssignee {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model ProjectTag {
  id        String    @id @default(uuid())
  name      String
  color     String
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     TaskTag[]
}

model TaskTag {
  taskId String
  tagId  String
  task   Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    ProjectTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model Attachment {
  id        String   @id @default(uuid())
  filename  String
  url       String
  taskId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  type      String // "assignment", "comment", "status"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String?
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(uuid())
  action    String
  details   String?
  createdAt DateTime @default(now())

  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
